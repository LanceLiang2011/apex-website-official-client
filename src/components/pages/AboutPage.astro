---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TutorGridSection from '../home/TutorGridSection.astro';
import type { Locale } from '../../data/types';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const title = locale === 'zh' ? '关于我们 - Apex Education' : 'About Us - Apex Education';
---

<BaseLayout title={title}>
  <!-- Hero -->
  <section class="bg-gray-900 text-white py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-30" style="background-image: url('https://images.unsplash.com/photo-1524178232363-1fb2b075b655?q=80&w=2070&auto=format&fit=crop');"></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">{locale === 'zh' ? '关于我们' : 'About Us'}</h1>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        {locale === 'zh' 
          ? 'Apex Education是一家加拿大教育机构，专注于语言培训、中小学课程辅导及升学规划，服务国际学生与本地学生家庭。' 
          : 'Apex Education is a Canadian educational institution specializing in language training, K-12 tutoring, and academic planning, serving both international and local student families.'}
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-lg text-gray-600">
          <p class="mb-8 text-lg leading-relaxed">
            {locale === 'zh' 
              ? '我们熟悉加拿大教育体系，致力于用清晰、可执行的方案，帮助学生稳步提升、顺利升学。'
              : 'We are well-versed in the Canadian education system and are committed to helping students achieve steady progress and successful advancement through clear, actionable plans.'}
          </p>

          <h2 class="text-3xl font-bold text-text-main mb-6">
            {locale === 'zh' ? '我们的优势' : 'Our Advantages'}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            {[
              { 
                icon: '🇨🇦',
                title: locale === 'zh' ? '深耕加拿大教育体系' : 'Deep Understanding of Canadian Education', 
                desc: locale === 'zh' ? '理解真实需求，提供符合本地标准的专业指导' : 'Understanding real needs and providing professional guidance aligned with local standards' 
              },
              { 
                icon: '📚',
                title: locale === 'zh' ? '教学与规划并重' : 'Teaching and Planning Combined', 
                desc: locale === 'zh' ? '关注长期发展，兼顾学术能力与升学目标' : 'Focusing on long-term development, balancing academic ability and admission goals' 
              },
              { 
                icon: '👥',
                title: locale === 'zh' ? '小班或一对一教学' : 'Small Classes or One-on-One', 
                desc: locale === 'zh' ? '个性化支持，确保每位学生得到充分关注' : 'Personalized support ensuring every student receives full attention' 
              },
              { 
                icon: '✨',
                title: locale === 'zh' ? '服务透明可追踪' : 'Transparent and Trackable Service', 
                desc: locale === 'zh' ? '沟通清晰，过程可追踪，让家长更放心' : 'Clear communication and trackable progress for parents\' peace of mind' 
              }
            ].map(item => (
              <div class="bg-gray-50 p-6 rounded-lg border border-gray-100">
                <div class="text-3xl mb-3">{item.icon}</div>
                <h3 class="font-bold text-primary-blue text-xl mb-2">{item.title}</h3>
                <p class="text-sm">{item.desc}</p>
              </div>
            ))}
          </div>

          <h2 class="text-3xl font-bold text-text-main mb-6">
            {locale === 'zh' ? '发展历程' : 'Our History'}
          </h2>
          <div class="border-l-2 border-primary-blue pl-6 space-y-8">
            {[
              { 
                year: '2018', 
                desc: locale === 'zh' 
                  ? 'Apex Education-Vancouver成立，专注于7-12课程辅导及语言培训' 
                  : 'Apex Education-Vancouver established, focusing on grades 7-12 tutoring and language training'
              },
              { 
                year: '2020', 
                desc: locale === 'zh' 
                  ? 'Apex Education-Montreal成立，专注于7-12课程辅导及语言培训' 
                  : 'Apex Education-Montreal established, focusing on grades 7-12 tutoring and language training'
              },
              { 
                year: '2021', 
                desc: locale === 'zh' 
                  ? 'Apex Education-Beijing成立，专注于语言培训及升学规划' 
                  : 'Apex Education-Beijing established, focusing on language training and academic planning'
              },
              { 
                year: '2021', 
                desc: locale === 'zh' 
                  ? 'Apex Education正式将旗下业务划归为简言语言培训中心(Simple Language Training)、优冠学术辅导中心(UCan Tutoring)和瑞思升学规划中心(Rise Academic Planning)三大部门' 
                  : 'Apex Education officially organized its operations into three divisions: Simple Language Training Center, UCan Tutoring Center, and Rise Academic Planning Center'
              },
              { 
                year: '2022', 
                desc: locale === 'zh' 
                  ? 'Apex Education旗下简言语言培训中心在广州成立' 
                  : 'Simple Language Training Center under Apex Education established in Guangzhou'
              },
              { 
                year: '2023', 
                desc: locale === 'zh' 
                  ? 'Apex Education旗下简言语言培训中心在武汉、郑州、无锡成立' 
                  : 'Simple Language Training Centers under Apex Education established in Wuhan, Zhengzhou, and Wuxi'
              },
              { 
                year: '2023', 
                desc: locale === 'zh' 
                  ? 'Apex Education-Winnipeg成立，专注于K-12课程辅导及语言培训' 
                  : 'Apex Education-Winnipeg established, focusing on K-12 tutoring and language training'
              },
              { 
                year: '2024', 
                desc: locale === 'zh' 
                  ? 'Apex Education-Richmond Hill成立，专注于K-12课程辅导、语言培训及升学规划' 
                  : 'Apex Education-Richmond Hill established, focusing on K-12 tutoring, language training, and academic planning'
              }
            ].map(item => (
              <div class="relative">
                <span class="absolute -left-[33px] top-1 w-4 h-4 rounded-full bg-primary-blue border-4 border-white shadow-sm"></span>
                <span class="text-primary-blue font-bold text-lg block mb-1">{item.year}</span>
                <p class="text-sm">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <TutorGridSection locale={locale} />

  <!-- Mission & Vision -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12">
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-8 rounded-2xl border border-blue-100">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">
            {locale === 'zh' ? '我们的使命' : 'Our Mission'}
          </h3>
          <p class="text-gray-700 leading-relaxed">
            {locale === 'zh'
              ? '以专业、诚信与责任感，帮助学员提升语言能力、拓展学术与职业路径，在全球化环境中获得长期发展的竞争力。'
              : 'With professionalism, integrity, and responsibility, we help students enhance language skills, expand academic and career paths, and gain long-term competitive advantage in a globalized environment.'}
          </p>
        </div>
        <div class="bg-gradient-to-br from-purple-50 to-pink-50 p-8 rounded-2xl border border-purple-100">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">
            {locale === 'zh' ? '我们的愿景' : 'Our Vision'}
          </h3>
          <p class="text-gray-700 leading-relaxed">
            {locale === 'zh'
              ? '成为值得信赖的加拿大教育品牌，让更多学员通过教育改变未来，并与世界建立更紧密的连接。'
              : 'To become a trusted Canadian education brand, enabling more students to transform their futures through education and build stronger connections with the world.'}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
